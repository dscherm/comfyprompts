{
  "_comment": "MMAudio: Generate matching audio/sound effects from video content. Requires ComfyUI-MMAudio custom node. Models go in models/mmaudio/.",
  "10": {
    "inputs": {
      "mmaudio_model": "mmaudio_large_44k_v2_fp16.safetensors",
      "base_precision": "fp16"
    },
    "class_type": "MMAudioModelLoader",
    "_meta": {
      "title": "MMAudio Model Loader"
    }
  },
  "20": {
    "inputs": {
      "vae_model": "mmaudio_vae_44k_fp16.safetensors",
      "synchformer_model": "mmaudio_synchformer_fp16.safetensors",
      "clip_model": "apple_DFN5B-CLIP-ViT-H-14-384_fp16.safetensors"
    },
    "class_type": "MMAudioFeatureUtilsLoader",
    "_meta": {
      "title": "MMAudio Feature Utils Loader"
    }
  },
  "30": {
    "inputs": {
      "video": "PARAM_STR_VIDEO_PATH",
      "force_rate": 0,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1
    },
    "class_type": "VHS_LoadVideo",
    "_meta": {
      "title": "Load Video"
    }
  },
  "40": {
    "inputs": {
      "mmaudio_model": [
        "10",
        0
      ],
      "feature_utils": [
        "20",
        0
      ],
      "images": [
        "30",
        0
      ],
      "prompt": "PARAM_STR_PROMPT",
      "duration": "PARAM_FLOAT_DURATION",
      "steps": "PARAM_INT_STEPS",
      "cfg": "PARAM_FLOAT_CFG",
      "seed": "PARAM_INT_SEED",
      "negative_prompt": "",
      "mask_away_clip": false,
      "force_offload": true
    },
    "class_type": "MMAudioSampler",
    "_meta": {
      "title": "MMAudio Sampler"
    }
  },
  "50": {
    "inputs": {
      "filename_prefix": "audio/video_audio",
      "quality": "V0",
      "audioUI": "",
      "audio": [
        "40",
        0
      ]
    },
    "class_type": "SaveAudioMP3",
    "_meta": {
      "title": "Save Audio (MP3)"
    }
  }
}