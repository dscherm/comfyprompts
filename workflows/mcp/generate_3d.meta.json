{
  "name": "Generate 3D from Text",
  "description": "Text-to-3D pipeline: generates an image from a text prompt using Flux, removes background with Inspyrenet rembg, then converts to a 3D mesh (.glb) using TripoSR.",
  "requirements": {
    "nodes": [
      "CheckpointLoaderSimple",
      "EmptySD3LatentImage",
      "CLIPTextEncode",
      "KSampler",
      "VAEDecode",
      "TripoSRModelLoader",
      "InspyrenetRembg",
      "TripoSRSampler",
      "SaveGLB"
    ],
    "custom_nodes": {
      "TripoSRModelLoader": {
        "install": "ComfyUI-TripoSR"
      },
      "TripoSRSampler": {
        "install": "ComfyUI-TripoSR"
      },
      "InspyrenetRembg": {
        "install": "ComfyUI-Inspyrenet-Rembg"
      }
    },
    "models": {
      "checkpoint": "sd_xl_base_1.0.safetensors",
      "triposr": "tripoSR.ckpt"
    },
    "minimum_vram_gb": 10
  },
  "parameters": {
    "prompt": {
      "type": "string",
      "required": true,
      "description": "Text description of desired 3D object"
    },
    "negative_prompt": {
      "type": "string",
      "required": false,
      "description": "Things to avoid"
    },
    "resolution": {
      "type": "int",
      "required": false,
      "description": "3D mesh geometry resolution"
    },
    "seed": {
      "type": "int",
      "required": false,
      "description": "Random seed"
    },
    "steps": {
      "type": "int",
      "required": false,
      "description": "Sampling steps"
    },
    "cfg": {
      "type": "float",
      "required": false,
      "description": "CFG scale"
    }
  },
  "output": {
    "type": "3d_mesh",
    "format": "glb",
    "node": "SaveGLB"
  },
  "category": "generation",
  "tags": [
    "text-to-3d",
    "triposr",
    "3d",
    "mesh"
  ],
  "defaults": {}
}