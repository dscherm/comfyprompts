{
  "1": {
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load SDXL Checkpoint"}
  },
  "2": {
    "inputs": {
      "control_net_name": "OpenPoseXL2.safetensors"
    },
    "class_type": "ControlNetLoader",
    "_meta": {"title": "Load OpenPose XL ControlNet"}
  },
  "3": {
    "inputs": {
      "image": "PARAM_STR_POSE_IMAGE",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {"title": "Load Blender Pose Image"}
  },
  "4": {
    "inputs": {
      "width": "PARAM_INT_WIDTH",
      "height": "PARAM_INT_HEIGHT",
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image"}
  },
  "5": {
    "inputs": {
      "text": "PARAM_PROMPT",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"}
  },
  "6": {
    "inputs": {
      "text": "PARAM_NEGATIVE_PROMPT",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"}
  },
  "7": {
    "inputs": {
      "strength": "PARAM_FLOAT_CONTROLNET_STRENGTH",
      "conditioning": ["5", 0],
      "control_net": ["2", 0],
      "image": ["3", 0]
    },
    "class_type": "ControlNetApply",
    "_meta": {"title": "Apply OpenPose ControlNet"}
  },
  "8": {
    "inputs": {
      "seed": "PARAM_INT_SEED",
      "steps": "PARAM_INT_STEPS",
      "cfg": "PARAM_FLOAT_CFG",
      "sampler_name": "PARAM_STR_SAMPLER_NAME",
      "scheduler": "PARAM_STR_SCHEDULER",
      "denoise": "PARAM_FLOAT_DENOISE",
      "model": ["1", 0],
      "positive": ["7", 0],
      "negative": ["6", 0],
      "latent_image": ["4", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"}
  },
  "9": {
    "inputs": {
      "samples": ["8", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "10": {
    "inputs": {
      "filename_prefix": "ComfyUI_BlenderPose",
      "images": ["9", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  }
}
