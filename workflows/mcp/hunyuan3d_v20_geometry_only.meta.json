{
  "name": "Hunyuan3D v2.0 Geometry Only",
  "description": "Geometry-only 3D mesh generation using Hunyuan3D v2.0 (no texture baking). Faster than the full textured pipeline. Outputs untextured GLB.",
  "requirements": {
    "nodes": [
      "Hy3DModelLoader",
      "Hy3DGenerateMesh",
      "Hy3DVAEDecode",
      "Hy3DPostprocessMesh",
      "Hy3DExportMesh",
      "TransparentBGSession+",
      "ImageRemoveBackground+",
      "ImageResize+"
    ],
    "models": {
      "diffusion_models": [
        "hy3dgen/hunyuan3d-dit-v2-0-fp16.safetensors"
      ]
    },
    "custom_nodes": [
      "ComfyUI-Hunyuan3DWrapper",
      "ComfyUI_essentials",
      "comfyui-inspyrenet-rembg"
    ],
    "vram_minimum_gb": 8,
    "vram_recommended_gb": 12
  },
  "parameters": {
    "PARAM_STR_IMAGE_PATH": {
      "type": "string",
      "description": "Path to input image",
      "required": true
    },
    "PARAM_FLOAT_GUIDANCE_SCALE": {
      "type": "float",
      "description": "Guidance scale for mesh generation",
      "default": 5.5,
      "min": 1.0,
      "max": 30.0
    },
    "PARAM_INT_STEPS": {
      "type": "int",
      "description": "Number of diffusion steps",
      "default": 50,
      "min": 10,
      "max": 100
    },
    "PARAM_INT_OCTREE_RESOLUTION": {
      "type": "int",
      "description": "Octree resolution for mesh extraction",
      "default": 256,
      "min": 64,
      "max": 512
    },
    "PARAM_INT_SEED": {
      "type": "int",
      "description": "Random seed (-1 for random)",
      "default": -1
    },
    "max_faces": {
      "type": "int",
      "required": false,
      "description": "Maximum face count for mesh decimation (default: 40000)"
    }
  },
  "tool": {
    "name": "hunyuan3d_v20_geometry_only",
    "description": "Generate geometry-only 3D mesh from image using Hunyuan3D v2.0 (no textures, faster)",
    "category": "3d_generation"
  }
}