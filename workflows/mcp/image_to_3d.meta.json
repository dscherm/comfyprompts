{
  "name": "Image to 3D",
  "description": "Converts a single image to a 3D mesh (.glb) using TripoSR. Automatically removes the background with Inspyrenet rembg before 3D reconstruction.",
  "requirements": {
    "nodes": ["LoadImage", "TripoSRModelLoader", "InspyrenetRembg", "TripoSRSampler", "SaveGLB"],
    "custom_nodes": {
      "TripoSRModelLoader": {"install": "ComfyUI-TripoSR"},
      "TripoSRSampler": {"install": "ComfyUI-TripoSR"},
      "InspyrenetRembg": {"install": "ComfyUI-Inspyrenet-Rembg"}
    },
    "models": {
      "triposr": "tripoSR.ckpt"
    },
    "minimum_vram_gb": 6
  },
  "parameters": {
    "image_path": {"type": "string", "required": true, "description": "Filename of the input image"},
    "resolution": {"type": "int", "required": false, "description": "3D mesh geometry resolution"}
  },
  "output": {
    "type": "3d_mesh",
    "format": "glb",
    "node": "SaveGLB"
  },
  "category": "conversion",
  "tags": ["image-to-3d", "triposr", "3d", "mesh", "reconstruction"]
}
