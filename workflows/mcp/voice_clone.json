{
  "_comment": "TTS-Audio-Suite: Voice cloning. Stage 1 generates base speech with F5-TTS (F5TTSEngineNode -> UnifiedTTSTextNode). Stage 2 converts it toward a target voice with the RVC engine (RVCEngineNode -> UnifiedVoiceChangerNode). The target voice is supplied as a reference via CharacterVoicesNode (narrator_target). NOTE: this TTS-Audio-Suite version exposes no input that consumes LoadRVCModelNode's RVC_MODEL output, so a pretrained RVC .pth is selected on the engine/auto-download path rather than wired in; PARAM_STR_RVC_MODEL names the target reference voice. Requires TTS-Audio-Suite custom node.",
  "20": {
    "inputs": {
      "language": "PARAM_STR_MODEL",
      "device": "auto",
      "temperature": 0.8,
      "speed": 1.0,
      "target_rms": 0.1,
      "cross_fade_duration": 0.15,
      "nfe_step": 32,
      "cfg_strength": 2.0
    },
    "class_type": "F5TTSEngineNode",
    "_meta": {
      "title": "F5 TTS Engine"
    }
  },
  "30": {
    "inputs": {
      "voice_name": "PARAM_STR_VOICE_REFERENCE",
      "reference_text": ""
    },
    "class_type": "CharacterVoicesNode",
    "_meta": {
      "title": "Source Voice"
    }
  },
  "10": {
    "inputs": {
      "TTS_engine": [
        "20",
        0
      ],
      "text": "PARAM_TEXT",
      "narrator_voice": "none",
      "seed": 1,
      "opt_narrator": [
        "30",
        0
      ]
    },
    "class_type": "UnifiedTTSTextNode",
    "_meta": {
      "title": "TTS Text"
    }
  },
  "45": {
    "inputs": {
      "pitch": "PARAM_INT_PITCH_SHIFT",
      "index_ratio": 0.75,
      "consonant_protection": 0.25,
      "volume_envelope": 0.25
    },
    "class_type": "RVCEngineNode",
    "_meta": {
      "title": "RVC Engine"
    }
  },
  "50": {
    "inputs": {
      "voice_name": "PARAM_STR_RVC_MODEL",
      "reference_text": ""
    },
    "class_type": "CharacterVoicesNode",
    "_meta": {
      "title": "RVC Target Voice"
    }
  },
  "40": {
    "inputs": {
      "TTS_engine": [
        "45",
        0
      ],
      "source_audio": [
        "10",
        0
      ],
      "narrator_target": [
        "50",
        0
      ],
      "refinement_passes": 1,
      "max_chunk_duration": 30,
      "chunk_method": "smart"
    },
    "class_type": "UnifiedVoiceChangerNode",
    "_meta": {
      "title": "Voice Changer (RVC)"
    }
  },
  "60": {
    "inputs": {
      "filename_prefix": "audio/voice_clone",
      "quality": "V0",
      "audio": [
        "40",
        0
      ]
    },
    "class_type": "SaveAudioMP3",
    "_meta": {
      "title": "Save Audio (MP3)"
    }
  }
}
