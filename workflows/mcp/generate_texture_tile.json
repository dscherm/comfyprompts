{
  "1": {
    "inputs": {
      "ckpt_name": "PARAM_STR_CHECKPOINT"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load Checkpoint"},
    "_defaults": {
      "PARAM_STR_CHECKPOINT": "juggernautXL_v9Rundiffusion.safetensors"
    }
  },
  "2": {
    "inputs": {
      "lora_name": "PARAM_STR_LORA_NAME",
      "strength_model": "PARAM_FLOAT_LORA_STRENGTH",
      "strength_clip": "PARAM_FLOAT_LORA_STRENGTH",
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": {"title": "Load Tile LoRA"},
    "_defaults": {
      "PARAM_STR_LORA_NAME": "style/SomeTile.safetensors",
      "PARAM_FLOAT_LORA_STRENGTH": 0.85
    }
  },
  "3": {
    "inputs": {
      "width": "PARAM_INT_WIDTH",
      "height": "PARAM_INT_HEIGHT",
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image"},
    "_defaults": {
      "PARAM_INT_WIDTH": 512,
      "PARAM_INT_HEIGHT": 512
    }
  },
  "4": {
    "inputs": {
      "text": "PARAM_PROMPT",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"}
  },
  "5": {
    "inputs": {
      "text": "PARAM_NEGATIVE_PROMPT",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"},
    "_defaults": {
      "PARAM_NEGATIVE_PROMPT": "blurry, text, watermark, 3d render, photo"
    }
  },
  "6": {
    "inputs": {
      "seed": "PARAM_INT_SEED",
      "steps": "PARAM_INT_STEPS",
      "cfg": "PARAM_FLOAT_CFG",
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0,
      "model": ["2", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["3", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"},
    "_defaults": {
      "PARAM_INT_SEED": -1,
      "PARAM_INT_STEPS": 25,
      "PARAM_FLOAT_CFG": 7.0
    }
  },
  "7": {
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "8": {
    "inputs": {
      "filename_prefix": "ComfyUI_Tile",
      "images": ["7", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  }
}
