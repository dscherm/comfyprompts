{
  "1": {
    "inputs": {
      "ckpt_name": "flux1-dev-fp8.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "Load Checkpoint"
    }
  },
  "2": {
    "inputs": {
      "string_a": "PARAM_STR_STYLE",
      "string_b": "character turnaround reference sheet, four views of the same character, full body, standing neutral pose: front view, left side profile view, right side profile view, back view, consistent character design and outfit across all views, evenly spaced figures, plain neutral background",
      "delimiter": ", "
    },
    "class_type": "StringConcatenate",
    "_meta": {
      "title": "Style + Turnaround Directive"
    }
  },
  "3": {
    "inputs": {
      "string_a": ["2", 0],
      "string_b": "PARAM_PROMPT",
      "delimiter": ", "
    },
    "class_type": "StringConcatenate",
    "_meta": {
      "title": "+ Character Description"
    }
  },
  "4": {
    "inputs": {
      "text": ["3", 0],
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Positive Prompt"
    }
  },
  "5": {
    "inputs": {
      "text": "PARAM_NEGATIVE_PROMPT",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Negative Prompt"
    }
  },
  "6": {
    "inputs": {
      "width": "PARAM_INT_WIDTH",
      "height": "PARAM_INT_HEIGHT",
      "batch_size": 1
    },
    "class_type": "EmptySD3LatentImage",
    "_meta": {
      "title": "Empty Latent"
    }
  },
  "7": {
    "inputs": {
      "seed": "PARAM_INT_SEED",
      "steps": "PARAM_INT_STEPS",
      "cfg": "PARAM_FLOAT_CFG",
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0]
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "KSampler"
    }
  },
  "8": {
    "inputs": {
      "samples": ["7", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "9": {
    "inputs": {
      "filename_prefix": "multiview_profile",
      "images": ["8", 0]
    },
    "class_type": "SaveImage",
    "_meta": {
      "title": "Save Image"
    }
  }
}
